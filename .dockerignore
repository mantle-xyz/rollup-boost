# Version control
.github
.gitignore

# Include for vergen constants
!/.git

# Build artifacts
**/target
integration_logs

# Development files
.vscode
.env
**/*.log


# Cargo artifacts
**/.cargo
# Note: DO NOT exclude Cargo.lock - it's needed for reproducible builds

# Documentation
**/*.md
docs/

# Scripts that aren't needed for runtime
scripts/
tests/
**/integration